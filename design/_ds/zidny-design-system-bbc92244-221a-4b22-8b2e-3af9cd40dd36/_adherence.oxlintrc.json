{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "decks/zidny-talks/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Outfit))/i]",
        "message": "Font not provided by the design system. Available: Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|status|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|leftIcon|rightIcon|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, leftIcon, rightIcon, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padded|interactive|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padded, interactive, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|actions|className|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, children, actions, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|icon|textarea|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, icon, textarea."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, hint, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:selectable|active|onRemove|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: selectable, active, onRemove, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|message|icon|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: variant, title, message, icon, onClose."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Avatar": { "replaces": [] },
      "Badge": { "replaces": [] },
      "Button": { "replaces": [] },
      "Card": { "replaces": [] },
      "Checkbox": { "replaces": [] },
      "Dialog": { "replaces": [] },
      "Icon": { "replaces": [] },
      "IconButton": { "replaces": [] },
      "Input": { "replaces": [] },
      "ProgressBar": { "replaces": [] },
      "Select": { "replaces": [] },
      "Switch": { "replaces": [] },
      "TabItem": { "replaces": [] },
      "Tag": { "replaces": [] },
      "Toast": { "replaces": [] }
    },
    "tokens": ["--blur-lg","--blur-md","--blur-sm","--blur-xl","--blur-xs","--body-leading","--body-size","--border-default","--border-strong","--border-subtle","--brand","--brand-active","--brand-hover","--brand-soft","--color-aqua-tint","--color-deep-navy","--color-light-gray","--color-pale-cyan","--color-primary-blue","--color-sky-blue","--color-warm-cream","--color-white","--container-2xl","--container-lg","--container-md","--container-sm","--container-xl","--danger","--danger-soft","--display-leading","--display-size","--display-weight","--divider","--duration-base","--duration-fast","--duration-slow","--ease-emphasis","--ease-in-out","--ease-standard","--eyebrow-size","--eyebrow-tracking","--eyebrow-weight","--focus-ring","--font-display","--font-mono","--font-sans","--glass-aqua","--glass-border-light","--glass-border-navy","--glass-border-soft","--glass-cyan","--glass-inner-bottom","--glass-inner-top","--glass-light","--glass-light-hi","--glass-navy","--glass-navy-hi","--glass-tint-cyan","--glass-tint-light","--glass-tint-navy","--glow-aqua","--glow-brand","--gradient-aqua","--gradient-deep","--gradient-sky","--gradient-wash","--h1-size","--h2-size","--h3-size","--h4-size","--info","--info-soft","--leading-normal","--leading-relaxed","--leading-snug","--leading-tight","--neutral-0","--neutral-100","--neutral-150","--neutral-200","--neutral-300","--neutral-400","--neutral-50","--neutral-500","--neutral-600","--neutral-700","--neutral-800","--neutral-900","--radius-2xl","--radius-lg","--radius-md","--radius-pill","--radius-round","--radius-sm","--radius-xl","--radius-xs","--shadow-glass","--shadow-glass-lg","--shadow-lg","--shadow-md","--shadow-sm","--shadow-xl","--shadow-xs","--sky-100","--sky-200","--sky-300","--sky-400","--sky-50","--sky-500","--sky-600","--sky-700","--sky-800","--sky-900","--space-0","--space-1","--space-10","--space-11","--space-12","--space-13","--space-14","--space-2","--space-3","--space-4","--space-5","--space-6","--space-7","--space-8","--space-9","--success","--success-soft","--surface-card","--surface-cream","--surface-info","--surface-navy","--surface-page","--surface-soft","--surface-sunken","--text-2xl","--text-2xs","--text-3xl","--text-4xl","--text-5xl","--text-6xl","--text-base","--text-body","--text-lg","--text-link","--text-md","--text-muted","--text-on-brand","--text-sm","--text-strong","--text-subtle","--text-xl","--text-xs","--tracking-normal","--tracking-snug","--tracking-tight","--tracking-wide","--tracking-wider","--warning","--warning-soft","--weight-bold","--weight-extra","--weight-light","--weight-medium","--weight-regular","--weight-semibold","--z-base","--z-modal","--z-overlay","--z-raised","--z-sticky","--z-toast","--z-tooltip"],
    "fontFamilies": ["Outfit"]
  }
}
