# Supabase project settings (Project Settings -> API in the Supabase dashboard).
# Browser-exposed -- safe to expose, RLS enforces access at the DB level.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS entirely -- only ever read in lib/supabase/admin.ts,
# which is imported exclusively by lib/portal/PortalClient.ts,
# lib/workflow/actions.ts, and lib/workflow/reviews.ts (all server-only
# modules). Never prefix this NEXT_PUBLIC_ and never import admin.ts from a
# Client Component. In Vercel, set this as a standard (non-"expose to
# browser") environment variable.
SUPABASE_SERVICE_ROLE_KEY=
